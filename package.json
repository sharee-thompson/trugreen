{
  "name": "trugreen-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "performance:audit": "playwright test tests/performance/performance-audit.spec.ts --project=chromium",
    "performance:report": "node scripts/build-performance-dashboard.js",
    "performance:audit-and-report": "npm run performance:audit && npm run performance:report",
    "test:storybook": "rm -f tests/visual/storybook/storybook-inventory.md && npx playwright test tests/visual/storybook/storybook.spec.ts --project=chromium",
    "test:storybook:all": "rm -f tests/visual/storybook/storybook-inventory.md && npx playwright test tests/visual/storybook/storybook.spec.ts",
    "test:storybook:update": "rm -f tests/visual/storybook/storybook-inventory.md && npx playwright test tests/visual/storybook/storybook.spec.ts --update-snapshots",
    "test:a11y": "npx playwright test tests/a11y/accessibility-audit.spec.ts",
    "test:link": "npx playwright test tests/link-validation/link-validator.spec.ts --project=chromium",
    "test:visual": "npx playwright test tests/visual/visual-regression.spec.ts",
    "test:smoke": "npx playwright test tests/functional/smoke.spec.ts",
    "test:buyflow-sanity": "npx playwright test tests/functional/buy-flow/buy-flow-e-sanity.spec.ts",
    "test:buyflow": "npx playwright test tests/functional/buy-flow/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "^25.6.0",
    "axe-html-reporter": "^2.2.11",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "playwright": "1.59.1"
  }
}