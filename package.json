{
  "name": "trugreen-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "performance:audit": "playwright test tests/performance/performance-audit.spec.ts --project=chromium",
    "performance:report": "node scripts/build-performance-dashboard.js",
    "performance:audit-and-report": "npm run performance:audit && npm run performance:report",
    "test:storybook": "rm -f tests/visual/storybook/storybook-inventory.md && PLAYWRIGHT_SNAPSHOT_SUITE=storybook npx playwright test tests/visual/storybook/storybook.spec.ts --project=chromium",
    "test:storybook:all": "rm -f tests/visual/storybook/storybook-inventory.md && PLAYWRIGHT_SNAPSHOT_SUITE=storybook npx playwright test tests/visual/storybook/storybook.spec.ts",
    "test:storybook:update": "rm -f tests/visual/storybook/storybook-inventory.md && PLAYWRIGHT_SNAPSHOT_SUITE=storybook npx playwright test tests/visual/storybook/storybook.spec.ts --project=chromium --update-snapshots",
    "test:a11y": "npx playwright test tests/a11y/accessibility-audit.spec.ts --project=chromium",
    "test:link": "npx playwright test tests/link-validation/link-validator.spec.ts --project=chromium",
    "test:visual": "PLAYWRIGHT_SNAPSHOT_SUITE=visual npx playwright test tests/visual/visual-regression.spec.ts",
    "test:visual:update": "PLAYWRIGHT_SNAPSHOT_SUITE=visual npx playwright test tests/visual/visual-regression.spec.ts --update-snapshots",
    "test:visual:landing": "PLAYWRIGHT_SNAPSHOT_SUITE=visual npx playwright test tests/visual/landing-pages",
    "test:visual:landing:update": "PLAYWRIGHT_SNAPSHOT_SUITE=visual npx playwright test tests/visual/landing-pages --update-snapshots",
    "test:visual:all": "PLAYWRIGHT_SNAPSHOT_SUITE=visual npx playwright test tests/visual",
    "test:smoke": "npx playwright test tests/functional/smoke.spec.ts",
    "test:buyflow-sanity": "npx playwright test tests/functional/buy-flow/buy-flow-e-sanity.spec.ts",
    "test:buyflow": "npx playwright test tests/functional/buy-flow/*",
    "test:lp-smoke": "npx playwright test tests/functional/landing-pages/smoke.spec.ts",
    "test:lp-deep": "npx playwright test tests/functional/landing-pages/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "axe-html-reporter": "^2.2.11",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2",
    "rrad": "^1.1.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "typescript": "^6.0.3"
  }
}
